{
    "version": 1,
    "id": "magic-missile",
    "spec": {
        "effects": [
            {"type": "damage", "config": {"amount": "1d4+2", "damage_types": "arcane"}}
        ],
        "command": {
            "category": "combat",
            "priority": 3,
            "description": "Conjure bolts of force that unerringly strike your target.",
            "config": {
                "resource": "mana",
                "resource_cost": "5",
                "ap_cost": "1",
                "message_actor": "You fire a magic missile at {{ .Targets.target.Name }}!",
                "message_target": "{{ .Actor.Name }} fires a magic missile at you!",
                "message_room": "{{ .Actor.Name }} fires a magic missile at {{ .Targets.target.Name }}!"
            },
            "inputs": [
                {"name": "target", "type": "string", "required": true, "missing": "Fire a magic missile at whom?"}
            ],
            "targets": [
                {
                    "name": "target",
                    "types": ["mobile", "player"],
                    "scopes": ["room"],
                    "input": "target",
                    "not_found": "You don't see '{{ .Inputs.target }}' here."
                }
            ]
        }
    }
}
