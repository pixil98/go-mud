{
    "version": 1,
    "id": "kick",
    "spec": {
        "effects": [
            {"type": "damage", "config": {"amount": "1d8+2"}}
        ],
        "command": {
            "category": "combat",
            "priority": 4,
            "description": "Deliver a swift kick to your target.",
            "config": {
                "ap_cost": "1",
                "message_actor": "You kick {{ .Targets.target.Name }}!",
                "message_target": "{{ .Actor.Name }} kicks you!",
                "message_room": "{{ .Actor.Name }} kicks {{ .Targets.target.Name }}!"
            },
            "inputs": [
                {"name": "target", "type": "string", "required": true, "missing": "Kick whom?"}
            ],
            "targets": [
                {
                    "name": "target",
                    "types": ["mobile"],
                    "scopes": ["room"],
                    "input": "target",
                    "not_found": "You don't see '{{ .Inputs.target }}' here."
                }
            ]
        }
    }
}
