            },
            "inputs": [
                {"name": "target", "type": "string", "required": true, "missing": "Backstab whom?"}
            ],
            "targets": [
                {
                    "name": "target",
                    "types": ["mobile"],
                    "scopes": ["room"],
                    "input": "target",
                    "not_found": "You don't see '{{ .Inputs.target }}' here."
                }
            ]
        }
    }
