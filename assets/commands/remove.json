{
    "version": 1,
    "id": "remove",
    "spec": {
        "handler": "move_obj",
        "aliases": ["unequip"],
        "category": "items",
        "description": "Remove an equipped item back to your inventory.",
        "config": {
            "destination": "inventory",
            "self_message": "You remove {{ .Targets.item.Obj.Name }}.",
            "room_message": "{{ .Actor.Name }} removes {{ .Targets.item.Obj.Name }}."
        },
        "targets": [
            {"name": "item", "types": ["object"], "scopes": ["equipment"], "input": "item", "not_found": "You don't have anything called '{{ .Inputs.item }}' equipped.", "allow_all": true}
        ],
        "inputs": [
            {"name": "item", "type": "string", "required": true, "missing": "Remove what?"}
        ]
    }
}
