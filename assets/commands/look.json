{
    "version": 1,
    "id": "look",
    "spec": {
        "handler": "look",
        "category": "information",
        "description": "Look at your surroundings or examine something.",
        "priority": 10,
        "targets": [
            {"name": "target", "types": ["player", "mobile", "object", "exit"], "scopes": ["room", "inventory"], "input": "target", "optional": true, "allow_unresolved": true}
        ],
        "inputs": [
            {"name": "target", "type": "string", "required": false}
        ],
        "config": {
            "target_input": "{{ .Inputs.target }}"
        }
    }
}
