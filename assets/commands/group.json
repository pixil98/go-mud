{
    "version": 1,
    "id": "group",
    "spec": {
        "handler": "group",
        "category": "group",
        "priority": 5,
        "description": "Show your group, or add/remove a follower from it.",
        "targets": [
            {
                "name": "target",
                "types": ["player", "mobile"],
                "scopes": ["followers"],
                "input": "target",
                "optional": true,
                "not_found": "{{ .Inputs.target }} isn't following you.",
                "allow_all": true
            }
        ],
        "inputs": [
            {"name": "target", "type": "string", "required": false}
        ]
    }
}
