{
    "version": 1,
    "id": "bash",
    "spec": {
        "name": "bash",
        "type": "skill",
        "handler": "damage",
        "description": "Bash a target with your shield.",
        "resource": "stamina",
        "resource_cost": 10,
        "cooldown": 4,
        "command": {
            "priority": 3,
            "description": "Bash a target with your shield.",
            "inputs": [
                {"name": "target", "type": "string", "required": true, "missing": "Bash whom?"}
            ],
            "targets": [
                {
                    "name": "target",
                    "types": ["mobile"],
                    "scopes": ["room"],
                    "input": "target",
                    "not_found": "You don't see '{{ .Inputs.target }}' here."
                }
            ]
        },
        "config": {
            "base_damage": 15
        },
        "messages": {
            "actor": "You bash {{ .Targets.target.Name }} with your shield!",
            "target": "{{ .Actor.Name }} bashes you with {{ .Actor.Pronoun.Get.Possessive.Adjective }} shield!",
            "room": "{{ .Actor.Name }} bashes {{ .Targets.target.Name }} with {{ .Actor.Pronoun.Get.Possessive.Adjective }} shield!"
        }
    }
}
