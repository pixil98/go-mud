{
    "version": 1,
    "id": "bash",
    "spec": {
        "effects": [
            {"type": "damage", "config": {"damage": "15"}}
        ],
        "command": {
            "category": "combat",
            "priority": 3,
            "description": "Bash a target with your shield.",
            "config": {
                "resource": "stamina",
                "resource_cost": "10",
                "ap_cost": "1",
                "message_actor": "You bash {{ .Targets.target.Name }} with your shield!",
                "message_target": "{{ .Actor.Name }} bashes you with {{ .Actor.Pronoun.Get.Possessive.Adjective }} shield!",
                "message_room": "{{ .Actor.Name }} bashes {{ .Targets.target.Name }} with {{ .Actor.Pronoun.Get.Possessive.Adjective }} shield!"
            },
            "inputs": [
                {"name": "target", "type": "string", "required": true, "missing": "Bash whom?"}
            ],
            "targets": [
                {
                    "name": "target",
                    "types": ["mobile"],
                    "scopes": ["room"],
                    "input": "target",
                    "not_found": "You don't see '{{ .Inputs.target }}' here."
                }
            ]
        }
    }
}
